{
  "manifest_version": 3,
  "name": "WorkBestie",
  "version": "1.0.0",
  "description": "Stop scrolling, start working. AI voice bestie that roasts you when you're distracted. Real-time callouts, GenZ energy. Focus accountability that hits different.",
  "permissions": ["tabs", "activeTab", "storage", "alarms", "offscreen", "scripting"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Work Bestie - Stay Focused",
    "default_icon": {
      "16": "icons/icon-safe-16.png",
      "32": "icons/icon-safe-32.png",
      "48": "icons/icon-safe-48.png",
      "128": "icons/icon-safe-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-safe-16.png",
    "32": "icons/icon-safe-32.png",
    "48": "icons/icon-safe-48.png",
    "128": "icons/icon-safe-128.png"
  },
  "host_permissions": ["https://api.elevenlabs.io/*", "<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
